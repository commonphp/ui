{
  "name": "comphp/ui",
  "type": "library",
  "description": "Driver-based UI rendering and reusable component support for PHP applications",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\UI\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\UI\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/runtime": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}